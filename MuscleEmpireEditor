-- Memory Baseline Caches
local startS1, startS2, startS3 = nil, nil, nil
local localPlayer = playersService.LocalPlayer

-- Tracking and Spy Loop Engine
task.spawn(function()
    while task.wait(0.2) do
        -- Local Player Tracking
        pcall(function()
            local s1Raw = findStatValue(localPlayer, {"Strength", "Power", "STRENGTH", "POWER"})
            local s2Raw = findStatValue(localPlayer, {"Durability", "Endurance", "Shield", "SHIELD", "DURABILITY", "ENDURANCE"})
            local s3Raw = findStatValue(localPlayer, {"Rebirths", "Rebirth", "Levels", "Level", "REBIRTH"})
            
            if s1Raw > 0 and startS1 == nil then startS1 = s1Raw end
            if s2Raw > 0 and startS2 == nil then startS2 = s2Raw end
            if s3Raw > 0 and startS3 == nil then startS3 = s3Raw end
            
            local _, s1Text = formatNumber(s1Raw)
            local _, s2Text = formatNumber(s2Raw)
            local _, s3Text = formatNumber(s3Raw)
            
            local diffS1 = s1Raw - (startS1 or s1Raw)
            local diffS2 = s2Raw - (startS2 or s2Raw)
            local diffS3 = s3Raw - (startS3 or s3Raw)
            
            local _, s1GainText = formatNumber(diffS1)
            local _, s2GainText = formatNumber(diffS2)
            local _, s3GainText = formatNumber(diffS3)
            
            PowerLabel:Set({Title = "💪 Power: " .. s1Text, Content = "Session Gained: +" .. s1GainText})
            ShieldLabel:Set({Title = "🛡️ Shield: " .. s2Text, Content = "Session Gained: +" .. s2GainText})
            RebirthsLabel:Set({Title = "🔥 Rebirths: " .. s3Text, Content = "Session Gained: +" .. s3GainText})
        end)

        -- Spy Target Player Tracking
        pcall(function()
            if SpyTarget and SpyTarget.Parent == playersService then
