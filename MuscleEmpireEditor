-- Teleport Logic
local function teleportBehind(npc)
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") and npc then
        -- Calculate position 3 studs behind and rotate 180 to face them
        local backPos = npc:GetPivot() * CFrame.new(0, 0, 3) * CFrame.Angles(0, math.rad(180), 0)
        char:PivotTo(backPos)
        char.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
    end
end

